{
  "name": "wars-app",
  "version": "0.1.0",
  "description": "",
  "main": "build/server.js",
  "type": "module",
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "clean:client": "rimraf dist/client",
    "clean:server": "rimraf dist",
    "build": "bun run build:server && bun run clean:client && bun run --bun vite build",
    "build:server": "tsc && tsc-alias",
    "dev:server": "bun run --bun --watch src/server.ts",
    "dev": "bun run --bun src/server.ts --dev",
    "start:prod": "bun run --bun dist/server.js",
    "test": "bun run --bun vitest",
    "test:run": "bun run --bun vitest run",
    "test:ui": "bun run --bun vitest --ui",
    "test:coverage": "bun run --bun vitest run --coverage",
    "fix": "biome format --write . && biome lint --write .",
    "fix:unsafe": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/client/tsconfig.json",
    "typecheck:server": "tsc --noEmit",
    "typecheck:client": "tsc --noEmit -p src/client/tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p test/tsconfig.json",
    "seed": "bun run --bun scripts/seed.ts",
    "seed:dry-run": "bun run --bun scripts/seed.ts --dry-run",
    "seed:service-areas": "bun run --bun scripts/seed-service-areas.ts",
    "migrate": "bun run --bun migrations/migrate.ts && bun run db:codegen",
    "migrate:rollback": "bun run --bun migrations/rollback.ts && bun run db:codegen",
    "db:codegen": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/wars bun run --bun kysely-codegen --dialect postgres --include-pattern 'public.*' --out-file src/services/database/types/database.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaymcalli/wars-app.git"
  },
  "homepage": "https://github.com/jaymcalli/wars-app#readme",
  "bugs": {
    "url": "https://github.com/jaymcalli/wars-app/issues"
  },
  "keywords": [],
  "author": "jamcalli",
  "license": "Apache-2.0",
  "dependencies": {
    "@epic-web/invariant": "^1.0.0",
    "@fastify/auth": "^5.0.4",
    "@fastify/autoload": "^6.3.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/session": "^11.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/vite": "^8.4.1",
    "@scalar/fastify-api-reference": "^1.34.2",
    "close-with-grace": "^2.4.0",
    "fastify": "^5.7.4",
    "fastify-zod-openapi": "^5.5.0",
    "kysely": "^0.28.11",
    "kysely-postgis": "^0.5.2",
    "kysely-postgres-js": "^3.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "vite": "^7.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@base-ui/react": "^1.2.0",
    "@bcgov/bc-sans": "^2.1.0",
    "@biomejs/biome": "^2.4.4",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "bun-types": "^1.3.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fastify-cli": "^7.4.1",
    "fastify-tsconfig": "^3.0.0",
    "kysely-codegen": "^0.20.0",
    "lucide-react": "^0.575.0",
    "maplibre-gl": "^5.19.0",
    "msw": "^2.12.10",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "rimraf": "^6.1.3",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "tsc-alias": "^1.8.16",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "vitest": "^4.0.18",
    "zustand": "^5.0.11"
  }
}
