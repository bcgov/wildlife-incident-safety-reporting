# Google Maps (injected into the SPA at request time via client-config plugin)
GOOGLE_MAPS_API_KEY=

# HMCR
HMCR_ID=
HMCR_SECRET=
HMCR_API_URL=
HMCR_TOKEN_URL=

# Seeding (presigned URL to historical CSV; used by scripts/seed.ts)
WARS_SEED_URL=
